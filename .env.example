# ============================================================
# MultiTrack Hub — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o .env com secrets reais.
# No Coolify, configure estas variáveis pelo painel, não via arquivo.
# ============================================================

# ─── Ambiente ───────────────────────────────────────────────
NODE_ENV=production

# ─── URLs públicas ──────────────────────────────────────────
# URL pública do site (usada em e-mails e redirecionamentos)
APP_URL=https://multitrack.macarsalao.com.br

# Origem permitida no CORS (deve ser igual a APP_URL em produção)
# Aceita múltiplas origens separadas por vírgula, ou * para qualquer origem (não recomendado)
CORS_ORIGIN=https://multitrack.macarsalao.com.br

# ─── Banco de dados ─────────────────────────────────────────
# Usuário do PostgreSQL
POSTGRES_USER=multitrack

# Senha do PostgreSQL — use uma senha forte e aleatória
POSTGRES_PASSWORD=TROQUE_ESTA_SENHA_POR_UMA_FORTE

# Nome do banco de dados
POSTGRES_DB=multitrack_db

# URL de conexão completa (usada pela aplicação)
# Formato: postgresql://USUARIO:SENHA@HOST:PORTA/BANCO
# No docker-compose, o host é o nome do serviço "postgres"
DATABASE_URL=postgresql://multitrack:TROQUE_ESTA_SENHA_POR_UMA_FORTE@postgres:5432/multitrack_db

# ─── Autenticação ───────────────────────────────────────────
# Segredo usado para derivar o hash de senhas
# Use um valor aleatório longo: openssl rand -hex 32
SESSION_SECRET=TROQUE_ESTE_SECRET_POR_UM_VALOR_ALEATORIO_LONGO

# ─── Porta da API (interno ao container) ────────────────────
# Não altere se estiver usando o docker-compose padrão
PORT=8080

# ─── Flags de controle — fluxos simulados ───────────────────
# ⚠️  MANTENHA false EM PRODUÇÃO COM CLIENTES REAIS.
# Defina true apenas em development ou staging controlado.

# Permite que POST /orders/:id/pay simule confirmação de pagamento.
# Em produção real, o pagamento deve vir do webhook do gateway (Mercado Pago, Pagar.me, Stripe).
ALLOW_FAKE_PAYMENTS=false

# Permite que POST /subscriptions/me crie assinaturas premium sem cobrança real.
# Em produção real, a assinatura deve ser ativada pelo webhook do gateway recorrente.
ALLOW_FAKE_SUBSCRIPTIONS=false

# Permite que POST /downloads/:grantId/link gere links placeholder sem storage real.
# Em produção real, configure S3 / Cloudflare R2 / MinIO e use URLs assinadas com expiração.
ENABLE_FAKE_DOWNLOAD_LINKS=false

# ─── Auto-deploy via webhook (opcional) ─────────────────────
# Segredo HMAC-SHA256 compartilhado com o GitHub para validar webhooks de deploy.
# Gere com: openssl rand -hex 32
# OBRIGATÓRIO se o serviço 'webhook' estiver ativo — o container não inicia sem este valor.
# Rotacione periodicamente e atualize no painel do GitHub (Settings → Webhooks).
WEBHOOK_SECRET=TROQUE_ESTE_SEGREDO_POR_UM_VALOR_ALEATORIO
